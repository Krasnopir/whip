WHIP_TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
WHIP_TELEGRAM_CHAT_ID=123456789
WHIP_DAEMON_PORT=7331
WHIP_TIMEOUT=1800

# По умолчанию в коде: all (каждый тул в Telegram). Тише: safe_reads | dangerous | all_bash | off
# WHIP_PRETOOL_MODE=safe_reads

# /limits и /reset: нужна строка Cookie с сайта claude.ai (это НЕ JWT и не API-ключ).
# Как взять: зайти на claude.ai в браузере → F12 → Network → обновить страницу →
# любой запрос к claude.ai → Headers → Request Headers → скопировать значение «cookie:»
# целиком одной строкой в эту переменную (без кавычек). Потом перезапустить демон.
#
# WHIP_CLAUDE_WEB_COOKIE=sessionKey=xxxx; __ssid=yyyy; cf_clearance=zzzz; ...
# WHIP_CLAUDE_USAGE_URL=https://claude.ai/settings/usage
